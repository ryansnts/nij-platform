# ══════════════════════════════════════════════════════════
# NIJ - Núcleo de Inteligência Jurídica
# Configuração do ambiente
# ══════════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────
SECRET_KEY=nij-dev-secret-key-manaus-2026-gac-nucleo-inteligencia-juridica
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────
POSTGRES_DB=nij_db
POSTGRES_USER=nij_user
POSTGRES_PASSWORD=nij_pass

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Frontend ─────────────────────────────────────────────
VITE_API_URL=http://localhost/api

# ── Storage ──────────────────────────────────────────────
MEDIA_ROOT=/app/media
MAX_UPLOAD_SIZE_MB=50

# ── Admin inicial (criado automaticamente) ───────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@NIJ2026
ADMIN_EMAIL=admin@nij.local

# ── CORS ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173
